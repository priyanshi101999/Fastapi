[Unit]
Description=Auto running fastApi app
After=network.target

[Service]
User=priyanshi
Group=priyanshi
WorkingDirectory=/home/priyanshi/app/src
Environment="PATH=/home/priyanshi/app/venv/bin"
EnvironmentFile=/home/priyanshi/.env
ExecStart=/home/priyanshi/app/venv/bin/gunicorn -w 4 -k uvicorn.workers.UvicornWorker app.main:app --bind 0.0.0.0:8000

[Install]
WantedBy=multi-user.target
